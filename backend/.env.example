# Database
DB_USER=ssssy
DB_PASSWORD=change_me_in_production

# JWT
JWT_SECRET=generate_a_strong_256bit_secret

# Storage (minio or local)
STORAGE_TYPE=minio
MINIO_ACCESS_KEY=ssssy_admin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=ssssy-media

# Application
APP_BASE_URL=https://ssssy.org.sy
LOG_LEVEL=INFO

# SMTP (optional - for email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@ssssy.org.sy
SMTP_PASSWORD=change_me_in_production

# IMAP (optional - for email sync)
IMAP_HOST=imap.example.com
IMAP_PORT=143
